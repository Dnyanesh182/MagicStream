# === MongoDB Atlas ===
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
DATABASE_NAME=magicstream

# === JWT Secrets (generate with: openssl rand -base64 32) ===
SECRET_KEY=your-256-bit-secret-here
SECRET_REFRESH_KEY=your-256-bit-refresh-secret-here

# === OpenAI / OpenRouter ===
OPENAI_API_KEY=sk-or-v1-your-openrouter-key-here
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openai/gpt-oss-120b:free
BASE_PROMPT_TEMPLATE=You are a movie ranking assistant. Based on the following review, classify the sentiment into ONE of these categories: {rankings}. Respond with ONLY the category name, nothing else.

# === CORS ===
ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# === Server ===
PORT=8080
GIN_MODE=debug
RECOMMENDED_MOVIE_LIMIT=5
